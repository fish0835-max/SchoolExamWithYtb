rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 照片出題上傳的教材照片
    match /photo_questions/{imageId} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024  // 5MB 上限
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
