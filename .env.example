# ============================================================
# 環境變數範本 — 複製為 .env 並填入真實值
# cp .env.example .env
#
# ⚠️  .env 已加入 .gitignore，絕對不可手動移除此規則
# ============================================================

# ── YouTube Data API（用於影片搜尋，基本嵌入播放不需要）──
# 至 https://console.developers.google.com 申請
YOUTUBE_API_KEY=

# ── Claude API（AI 出題 / 照片出題）──
# 至 https://console.anthropic.com 申請
CLAUDE_API_KEY=

# ── Firebase（本機開發參考，正式環境由 firebase_options.dart 提供）──
# 執行 `flutterfire configure` 自動產生 lib/firebase_options.dart
FIREBASE_PROJECT_ID=schoolexam-b5cc7
